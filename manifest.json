{
  "manifest_version": 3,
  "name": "DirtyCHAT",
  "description": "Privately export conversations from multiple AI platforms with customization, Gemini, and Notion API.",
  "version": "1.1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://chat.together.ai/*",
    "https://chatgpt.com/*",
    "https://grok.com/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://chat.qwenlm.ai/*",
    "https://qwen.ai/*",
    "https://chat.deepseek.com/*",
    "https://z.ai/*",
    "https://hailuoai.com/*",
    "https://mimo.mi.com/*",
    "https://platform.xiaomimimo.com/*",
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.together.ai/*",
        "https://chatgpt.com/*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://chat.qwenlm.ai/*",
        "https://qwen.ai/*",
        "https://chat.deepseek.com/*",
        "https://z.ai/*",
        "https://hailuoai.com/*",
        "https://mimo.mi.com/*",
        "https://platform.xiaomimimo.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
